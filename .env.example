# Shared application configuration
PORT=3000
LOG_LEVEL=info

# Development with Neon Local
NODE_ENV=development
DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb
NEON_LOCAL_HOST=neon-local
NEON_LOCAL_PORT=5432
NEON_API_KEY=replace-with-neon-api-key
NEON_PROJECT_ID=replace-with-neon-project-id
PARENT_BRANCH_ID=

# Production with Neon Cloud
# NODE_ENV=production
# DATABASE_URL=postgres://<user>:<password>@<project-endpoint>.neon.tech/neondb?sslmode=require